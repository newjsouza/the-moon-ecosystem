# ═══════════════════════════════════════════════
#  The Moon Ecosystem — .gitignore
# ═══════════════════════════════════════════════

# ── Secrets (NUNCA commitar) ──────────────────
.env
*.env
.env.*
config/keys.json
config/secrets.json
**/secrets/
**/*_secret*
**/*_credentials*

# ── Dados em tempo de execução ────────────────
data/nexus/
data/bot_tasks/
data/devops_reports/auto_heal_backups/
data/economic_sentinel/
data/omni_channel/
data/hardware_bridge/
data/knowledge_graph/
data/reports/
data/blog_exports/
data/cli_harness_results/
data/reviews/
data/plans/
data/news/
learning/workspaces/alchemist/quarantine/
learning/workspaces/alchemist/discoveries/
learning/knowledge_graph/embeddings.npz
learning/research_vault/
learning/workspaces_test/

# ── Harnesses gerados automaticamente ─────────
skills/cli_harnesses/generated/cli_abc123xyz_*.py
skills/cli_harnesses/generated/cli_jq_*.py

# ── Binários e arquivos grandes ───────────────
*.tar.xz
*.tar.gz
*.zip
*.7z
infrastructure/ffmpeg
infrastructure/ffprobe
infrastructure/ffplay
ffmpeg-release-*

# ── Python ────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml
*.cover

# ── Ambientes virtuais ────────────────────────
venv/
.venv/
env/
ENV/
.env.bak

# ── Node / TypeScript (workspace_monitor) ────
node_modules/
apps/workspace_monitor/dist/
apps/workspace_monitor/.next/
apps/workspace_monitor/build/
*.tsbuildinfo
.npm/

# ── IDEs ──────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.cursor/

# ── SO ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*~

# ── Logs ──────────────────────────────────────
*.log
logs/
*.pid

# ── Temporários ───────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.bak_*

# ── Runtime data — não versionar ──────────────
runtime/
runtime/flows/
*.jsonl_*
runtime/flows/runs.jsonl
data/pipeline/*.db
data/pipeline/*.csv
data/pipeline/*.json
data/screenshots/
.env
