{
  "name": "apex_pipeline",
  "session_mode": "channel",
  "steps": [
    {
      "name": "fetch_games",
      "agent": "webmcp",
      "task": "jogos de hoje futebol brasileiro",
      "depends_on": [],
      "on_error": "stop",
      "timeout": 30.0,
      "max_retries": 2,
      "retry_delay": 3.0
    },
    {
      "name": "fetch_lineups",
      "agent": "webmcp",
      "task": "escalações das partidas de hoje",
      "depends_on": ["fetch_games"],
      "on_error": "continue",
      "timeout": 60.0,
      "max_retries": 1,
      "retry_delay": 5.0
    },
    {
      "name": "analyze",
      "agent": "apex",
      "task": "analisar partidas com dados disponíveis e gerar análise de apostas",
      "depends_on": ["fetch_lineups"],
      "on_error": "stop",
      "timeout": 90.0,
      "max_retries": 1,
      "retry_delay": 2.0
    },
    {
      "name": "notify",
      "agent": "telegram",
      "task": "enviar análise APEX via Telegram",
      "depends_on": ["analyze"],
      "on_error": "continue",
      "timeout": 15.0,
      "max_retries": 2,
      "retry_delay": 1.0
    }
  ]
}