"""
agents/opencode.py
Integration with OpenCode specialized LLMs.
Connects to the local OpenCode server for high-performance coding and research models.
"""
import aiohttp
import json
import logging
from typing import Dict, Any, List, Optional
from core.agent_base import AgentBase, TaskResult, AgentPriority
from utils.logger import setup_logger

class OpenCodeAgent(AgentBase):
    """
    Agent specialized in utilizing OpenCode's local model serving.
    Targets specialized models like MiniMax M2.5 and Nemotron 3 Super.
    """

    def __init__(self):
        super().__init__()
        self.priority = AgentPriority.HIGH
        self.description = "OpenCode Specialized LLM Provider"
        self.logger = setup_logger("OpenCodeAgent")
        self.api_base = "http://localhost:59974/v1"
        
        # Model mapping for specialized tasks
        self.SPECIALIZED_MODELS = {
            "coding": "minimax-m2.5",
            "research": "nemotron-3-super",
            "fast": "gpt-5-nano",
            "free": "big-pickle",
            "moe": "mimo-v2-flash"
        }

    async def _execute(self, task: str, **kwargs) -> TaskResult:
        """
        Executes a completion request via OpenCode.
        Can specify 'specialty' or 'model' in kwargs.
        """
        prompt = kwargs.get("prompt", task)
        specialty = kwargs.get("specialty")
        model = kwargs.get("model")
        
        # Determine model
        if not model:
            if specialty and specialty in self.SPECIALIZED_MODELS:
                model = self.SPECIALIZED_MODELS[specialty]
            else:
                model = self.SPECIALIZED_MODELS["free"] # Default to big-pickle

        temperature = kwargs.get("temperature", 0.7)
        max_tokens = kwargs.get("max_tokens", 4096)

        payload = {
            "model": model,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": temperature,
            "max_tokens": max_tokens
        }

        try:
            self.logger.info(f"Requesting OpenCode model: {model} (Specialty: {specialty})")
            async with aiohttp.ClientSession() as session:
                async with session.post(f"{self.api_base}/chat/completions", json=payload) as resp:
                    if resp.status != 200:
                        error_text = await resp.text()
                        return TaskResult(success=False, error=f"OpenCode API error ({resp.status}): {error_text}")
                    
                    data = await resp.json()
                    response_text = data["choices"][0]["message"]["content"]
                    return TaskResult(
                        success=True, 
                        data={
                            "response": response_text, 
                            "model_used": model,
                            "provider": "OpenCode"
                        }
                    )
        except Exception as e:
            self.logger.error(f"OpenCode connection failed: {e}")
            return TaskResult(success=False, error=f"Failed to connect to OpenCode: {str(e)}")

    async def list_models(self) -> List[str]:
        """Fetch list of active models from OpenCode."""
        try:
            async with aiohttp.ClientSession() as session:
                async with session.get(f"{self.api_base}/models") as resp:
                    if resp.status == 200:
                        data = await resp.json()
                        return [m["id"] for m in data.get("data", [])]
            return []
        except Exception:
            return []
