# ═══════════════════════════════════════════════════
#  The Moon Ecosystem — Template de variáveis de ambiente
#  COPIE para .env e preencha com seus valores reais
#  NUNCA commite o arquivo .env
#
#  HIERARQUIA DE FALLBACK LLM:
#  1. Groq Cloud (primário) → llama-3.3-70b, llama-3.1-8b
#  2. Google Gemini (secundário) → gemini-2.0-flash
#  3. OpenRouter (terciário) → modelos open-source
#  4. Modo Degradado (final) → resposta determinística
# ═══════════════════════════════════════════════════

# ── LLM Principal (OBRIGATÓRIO) ────────────────────
GROQ_API_KEY=sua_groq_api_key_aqui
# Obter em: https://console.groq.com/keys

# ── LLM Fallback (OPCIONAIS — aumentam resiliência) ─
GEMINI_API_KEY=sua_gemini_api_key_aqui
# Obter em: https://makersuite.google.com/app/apikey
# Free tier: 15 req/min

OPENROUTER_API_KEY=sua_openrouter_api_key_aqui
# Obter em: https://openrouter.ai/keys
# Free tier disponível para modelos open-source

# ── Telegram ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui
TELEGRAM_CHANNEL_ID=

# ── GitHub ────────────────────────────────────────
GITHUB_TOKEN=seu_github_token_aqui
GITHUB_REPO=newjsouza/the-moon-ecosystem
GITHUB_MONITOR_REPOS=browserbase/stagehand,anthropics/claude-code

# ── Bot Configurações ─────────────────────────────
MOON_ALLOW_ALL_COMMANDS=0
MOON_HOTKEY=ctrl+space
MOON_MIC_DEVICE=

# ── OpenCode (LLM local — opcional) ───────────────
OPENCODE_API_BASE=http://localhost:59974/v1

# ── Redes sociais (OmniChannelStrategist) ─────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=
LINKEDIN_ORG_URN=

# ── Apostas (EconomicSentinel) ────────────────────
ODDS_API_KEY=
SENTINEL_BANKROLL=0

# ── Supabase (MemoryAgent — RAG persistente) ─────
# Projeto: ntrgbqvywscifjcdwwyb
# Obter em: https://supabase.com/dashboard/project/ntrgbqvywscifjcdwwyb/settings/api
SUPABASE_URL=https://ntrgbqvywscifjcdwwyb.supabase.co
SUPABASE_KEY=sua_service_key_ou_anon_key_aqui

# ── Infraestrutura (custos mensais em BRL) ────────
INFRA_VPS_MONTHLY=0
INFRA_DOMAIN_MONTHLY=0
INFRA_BACKUPS_MONTHLY=0
INFRA_OTHER_MONTHLY=0
