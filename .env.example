# ══════════════════════════════════════════
# The Moon Ecosystem — Environment Variables
# Copy to .env and fill in your real values
# NEVER commit .env to git
# ══════════════════════════════════════════

# ── LLM Providers (required) ──────────────
GROQ_API_KEY=gsk_your_key_here
GEMINI_API_KEY=AIzaSy_your_key_here
OPENROUTER_API_KEY=sk-or-your_key_here

# ── Integrations (required) ───────────────
TELEGRAM_BOT_TOKEN=123456789:your_token_here
TELEGRAM_CHAT_ID=123456789
GITHUB_TOKEN=ghp_your_token_here

# ── Sentinel Autonomy (optional) ───────────
MOON_SENTINEL_AUTO_IMPLEMENT=true
MOON_SENTINEL_IMPL_COOLDOWN_SECONDS=1800
MOON_SENTINEL_TELEGRAM_DEDUP_SECONDS=21600

# ── Database (optional — for MemoryAgent) ─
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGc...your_key_here

# ── Sports Analytics (optional) ───────────
FOOTBALL_DATA_API_KEY=your_key_here

# ── Email / Gmail (optional) ──────────────
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret

# ── Code Execution (optional) ─────────────
OPENCODE_API_BASE=http://localhost:8080
# ── YouTube Data API v3 (opcional — free 10k units/day) ──
YOUTUBE_API_KEY=your_key_here
